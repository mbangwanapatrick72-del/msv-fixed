# Firebase Admin SDK Credentials (for Vercel environment variables)
# Get these from: Firebase Console → Project Settings → Service Accounts → Generate New Private Key

# Project ID
FIREBASE_PROJECT_ID=doctor-web-app-a29a5

# Private Key (keep this SECRET! Use \n for newlines)
# Format: -----BEGIN PRIVATE KEY-----\n...content...\n-----END PRIVATE KEY-----\n
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Client Email from service account
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-fbsvc@doctor-web-app-a29a5.iam.gserviceaccount.com

# Next.js Environment
NEXT_PUBLIC_API_URL=http://localhost:3000
